# ── App ─────────────────────────────────────────────────
APP_NAME="MyApp API"
APP_VERSION="0.1.0"
ENVIRONMENT=dev          # dev | stage | prod
DEBUG=true

# ── Server ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=2                # Use 2-4 for Render; 1 for a small VM

# ── Database ───────────────────────────────────────────
# SQLAlchemy async URL (asyncpg driver)
# - Render Postgres: copy from Render dashboard and change `postgresql://` -> `postgresql+asyncpg://`
# - Supabase:
#   - App runtime can use the Supabase Pooler endpoint (typically :6543).
#   - Alembic migrations are often more reliable via the direct DB host (typically :5432).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/myapp
# Optional (recommended for Supabase): direct DB URL for migrations
# ALEMBIC_DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres
# Supabase TLS behavior:
# - verify-full (default): verify cert chain + hostname
# - require: encrypt but skip verification (use only if your environment fails with CERTIFICATE_VERIFY_FAILED)
# - disable: no TLS (not recommended)
DB_SSLMODE=verify-full
DB_POOL_SIZE=10          # 10 for Render; 3-5 for a small VM
DB_MAX_OVERFLOW=3        # 3 for Render; 0 for a small VM
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300

# ── Docker Compose Postgres ───────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=myapp
DB_PORT=5432
APP_PORT=8000

# ── Auth / JWT ─────────────────────────────────────────
# NOTE: Local JWT auth endpoints are retired in this project.
# These values remain only for backward-compatibility / future toggles.
# Generate with:  openssl rand -hex 32
SECRET_KEY=CHANGE-ME-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Supabase Auth (required for protected endpoints) ───
# Configure these so the backend can verify Supabase-issued access tokens.
# Typical values:
# - SUPABASE_ISSUER: https://<project-ref>.supabase.co/auth/v1
# - SUPABASE_JWKS_URL: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_ISSUER=
SUPABASE_JWKS_URL=
# Optional: used as `apikey` header if your JWKS endpoint is protected.
SUPABASE_ANON_KEY=
# Defaults are fine for most Supabase setups.
SUPABASE_AUDIENCE=authenticated
SUPABASE_JWKS_CACHE_TTL_SECONDS=3600
SUPABASE_ACCEPTED_ALGS=["RS256","ES256"]

# ── CORS ───────────────────────────────────────────────
# Comma-separated origins, or ["*"] for dev
CORS_ORIGINS=["*"]

# ── n8n (optional) ────────────────────────────────────
N8N_WEBHOOK_URL=
N8N_API_KEY=
